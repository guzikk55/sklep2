<%- include('../partials/header') %>
<div class="card" style="max-width: 600px; margin: auto;">
    <h2>Nowa Aukcja</h2>
    <form action="/seller/add" method="POST">
        <input type="text" name="name" placeholder="Nazwa produktu" required>
        <input type="number" name="price" placeholder="Cena" required>
        <input type="text" name="category" placeholder="Kategoria">
        <textarea name="description" placeholder="Opis produktu"></textarea>
        <button type="submit" style="width: 100%;">Wystaw przedmiot</button>
    </form>
</div>
<%- include('../partials/footer') %>